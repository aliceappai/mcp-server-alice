{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.aliceappai/mcp-server-alice",
  "description": "Secure audio transcription meets AI. Connect Alice recordings to Claude, ChatGPT, Gemini, and more.",
  "repository": {
    "url": "https://github.com/aliceappai/mcp-server-alice",
    "source": "github"
  },
  "version": "1.1.0",
  "privacy_policies": [
    "https://aliceapp.ai/privacy-policy"
  ],
  "tools": [
    {
      "name": "list_recordings_v2",
      "readOnlyHint": true
    },
    {
      "name": "search_recordings_v2",
      "readOnlyHint": true
    },
    {
      "name": "get_recording_v2",
      "readOnlyHint": true
    },
    {
      "name": "get_transcript_v2",
      "readOnlyHint": true
    },
    {
      "name": "get_collection_stats_v2",
      "readOnlyHint": true
    },
    {
      "name": "get_schemas_v2",
      "readOnlyHint": true
    },
    {
      "name": "search_recordings_tool",
      "readOnlyHint": true
    },
    {
      "name": "get_transcript_tool",
      "readOnlyHint": true
    },
    {
      "name": "get_recording_metadata_tool",
      "readOnlyHint": true
    },
    {
      "name": "list_recent_recordings_tool",
      "readOnlyHint": true
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://aliceapp.ai/mcp/{api_key}",
      "variables": {
        "api_key": {
          "description": "Your Alice API key, found in your Alice Dashboard under Settings → API",
          "isRequired": true
        }
      }
    }
  ]
}