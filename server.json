{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.aliceappai/mcp-server-alice",
  "description": "Connect your Alice recordings and transcripts to any MCP-compatible AI client. Search, retrieve, and build workflows across your secure voice archive with natural language.",
  "repository": {
    "url": "https://github.com/aliceappai/mcp-server-alice",
    "source": "github"
  },
  "version": "1.0.1",
  "privacy_policies": [
    "https://aliceapp.ai/privacy-policy"
  ],
  "tools": [
    {
      "name": "list_recordings",
      "readOnlyHint": true
    },
    {
      "name": "get_transcript",
      "readOnlyHint": true
    },
    {
      "name": "search_recordings",
      "readOnlyHint": true
    },
    {
      "name": "get_recording_metadata",
      "readOnlyHint": true
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://aliceapp.ai/mcp/{api_key}",
      "variables": {
        "api_key": {
          "description": "Your Alice API key, found in your Alice Dashboard under Settings → API",
          "isRequired": true
        }
      }
    }
  ]
}